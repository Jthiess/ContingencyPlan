FLASK_PORT=5000
# ── Discord ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
GUILD_ID=123456789012345678

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contingencyplan
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SCHEMA=public

# ── Downloads ────────────────────────────────────────────────
# Directory where avatars, attachments, emojis, etc. are saved
DOWNLOAD_DIR=./downloads

# ── Authentication (Authentik SSO) ───────────────────────────
# Base URL of your Authentik instance (no trailing slash)
AUTHENTIK_BASE_URL=https://auth.example.com
# OAuth2 application credentials from Authentik
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret
# Public URL of this app (used as OAuth2 redirect URI base)
BASE_URL=http://localhost:5000
# Flask session secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_secret_here
# Comma-separated Authentik usernames that always have admin rights
# The first user to sign in is automatically made admin regardless of this list
ADMIN_USERS=yourusername
